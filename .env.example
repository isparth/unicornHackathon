NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
RESERVATION_HOLD_MINUTES=120
DEFAULT_CURRENCY=gbp
DEFAULT_CALLOUT_FEE_PENCE=8000
DEFAULT_REPAIR_MIN_PENCE=10000
DEFAULT_REPAIR_MAX_PENCE=25000
# Secret used to sign intake form tokens (HMAC-SHA256). Use a long random string.
INTAKE_TOKEN_SECRET=replace-with-a-long-random-secret
# How long (in minutes) an intake form token remains valid after issue. Default: 30.
INTAKE_TOKEN_EXPIRY_MINUTES=30
# OpenAI API key — used for call summary generation and classification.
OPENAI_API_KEY=replace-with-your-openai-api-key
# OpenAI model used for call summary generation. Default: gpt-4.1-mini.
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
# Stripe keys — get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace-with-your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_replace-with-your-stripe-publishable-key
# Stripe webhook signing secret — get from Dashboard → Developers → Webhooks (wired in Milestone 4).
STRIPE_WEBHOOK_SECRET=whsec_replace-with-your-webhook-secret
# Public URL of the app — used for Stripe success/cancel redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Twilio credentials — used for outbound SMS (intake form link, payment link, booking confirmation).
# Account SID and Auth Token: https://console.twilio.com → Account Info
# From number: your SMS-capable Twilio number in E.164 format (e.g. +447xxxxxxxxx)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
TWILIO_FROM_NUMBER=+447xxxxxxxxx
# Vapi credentials — used for the voice webhook and (future) Vapi API calls.
# API key: https://dashboard.vapi.ai → API Keys → Private key
# Webhook secret: a random string you configure in your Vapi assistant's server URL settings.
VAPI_API_KEY=replace-with-your-vapi-private-api-key
VAPI_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
